// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String          @id @unique @default(uuid())
  email                   String          @unique
  display_name            String
  user_name               String
  password                String?
  profile_pic             ProfilePhoto?
  birth_date              DateTime?
  provider                String?


  rooms                   Room[]
  text_messages_sent      TextMessage[]   @relation("text-sent")
  text_messages_received  TextMessage[]   @relation("text-received")
  photo_messages_sent     PhotoMessage[]  @relation("photo-sent")
  photo_messages_received PhotoMessage[]  @relation("photo-received")
  video_messages_sent     VideoMessage[]  @relation("video-sent")
  video_messages_received VideoMessage[]  @relation("video-received")
  friend_request_receiver FriendRequest[] @relation("friendRequestReceiver")
  friend_request_sender   FriendRequest[] @relation("friendRequestSender")
  friends                 Friendship[]    @relation("friends")
  friends_with            Friendship[]    @relation("friendsWith")


  created_at              DateTime        @default(now())
}

model ProfilePhoto {
  id         String   @id @unique @default(uuid())
  owner      User     @relation(fields: [owner_id], references: [id])
  owner_id   String   @unique
  photo_url  String
  created_at DateTime @default(now())
}

model Room {
  id             String         @id @unique @default(uuid())
  name           String
  members        User[]
  text_messages  TextMessage[]
  photo_messages PhotoMessage[]
  video_messages VideoMessage[]
  created_at     DateTime       @default(now())
}

model TextMessage {
  id               String       @id @unique @default(uuid())
  sender           User    @relation("text-sent", fields: [sender_id], references: [id])
  sender_id        String
  user_receiver    User?   @relation("text-received", fields: [user_receiver_id], references: [id])
  user_receiver_id String?
  room_receiver    Room    @relation(fields: [room_receiver_id], references: [id])
  room_receiver_id String

  content String

  created_at DateTime @default(now())
}

model PhotoMessage {
  id               String  @id @unique @default(uuid())
  sender           User    @relation("photo-sent", fields: [sender_id], references: [id])
  sender_id        String
  user_receiver    User?   @relation("photo-received", fields: [user_receiver_id], references: [id])
  user_receiver_id String?
  room_receiver    Room    @relation(fields: [room_receiver_id], references: [id])
  room_receiver_id String

  photo_url  String
  created_at DateTime @default(now())
}

model VideoMessage {
  id String @id @unique @default(uuid())

  sender    User   @relation("video-sent", fields: [sender_id], references: [id])
  sender_id String

  user_receiver    User?   @relation("video-received", fields: [user_receiver_id], references: [id])
  user_receiver_id String?

  room_receiver    Room   @relation(fields: [room_receiver_id], references: [id])
  room_receiver_id String

  video_url  String
  name       String
  length     Int
  created_at DateTime @default(now())
}

model Otp {
  id         String   @id @unique @default(uuid())
  email      String
  value      String
  created_at DateTime @default(now())
}

model FriendRequest {
  id          String @id @unique @default(uuid())
  receiver    User   @relation("friendRequestReceiver", fields: [receiver_id], references: [id])
  receiver_id String
  sender      User   @relation("friendRequestSender", fields: [sender_id], references: [id])
  sender_id   String

  date_created DateTime @default(now())

  @@unique([sender_id, receiver_id])
}

model Friendship {
  id          String @id @unique @default(uuid())
  user_1      User   @relation("friends", fields: [friend_1_id], references: [id], onDelete: Cascade)
  friend_1_id String
  user_2      User   @relation("friendsWith", fields: [friend_2_id], references: [id], onDelete: Cascade)
  friend_2_id String

  created_at DateTime @default(now())

  @@unique([friend_1_id, friend_2_id])
}
