generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String               @id @unique @default(uuid())
  email                   String               @unique
  password                String?
  profile_photo           ProfilePhoto?
  birth_date              DateTime?
  display_name            String
  user_name               String
  provider                String?
  friend_request_sent     FriendRequest[]      @relation("friend-request-sender")
  friend_request_received FriendRequest[]      @relation("friend-request-receiver")
  friends                 Friendship[]         @relation("friend1")
  friends_with            Friendship[]         @relation("friend2")
  direct_messages         DirectConversation[] @relation("direct-message1")
  direct_messages_        DirectConversation[] @relation("direct-message2")
  direct_message_sent     Message[]            @relation("message-sent")
  direct_message_received Message[]            @relation("message-received")
  room_mesages_sent       RoomMessage[]        @relation("room-message-sender")
  date_created            DateTime             @default(now())
}

model ProfilePhoto {
  id           String   @id @unique @default(uuid())
  owner        User     @relation(fields: [owner_id], references: [id])
  owner_id     String   @unique
  photo_url    String
  date_created DateTime @default(now())
}

model FriendRequest {
  id           String   @id @unique @default(uuid())
  receiver     User     @relation("friend-request-receiver", fields: [receiver_id], references: [id])
  receiver_id  String
  sender       User     @relation("friend-request-sender", fields: [sender_id], references: [id])
  sender_id    String
  date_created DateTime @default(now())

  @@unique([sender_id, receiver_id])
}

model Friendship {
  id           String   @id @unique @default(uuid())
  friend_1     User     @relation("friend1", fields: [friend_1_id], references: [id], onDelete: Cascade)
  friend_1_id  String
  friend_2     User     @relation("friend2", fields: [friend_2_id], references: [id], onDelete: Cascade)
  friend_2_id  String
  date_created DateTime @default(now())

  @@unique([friend_1_id, friend_2_id])
}

model DirectConversation {
  id           String    @id @unique 
  user1        User      @relation("direct-message1", fields: [user1_id], references: [id])
  user1_id     String
  user2        User      @relation("direct-message2", fields: [user2_id], references: [id])
  user2_id     String
  messages     Message[]
  date_created DateTime  @default(now())

  @@unique([user1_id, user2_id])
}

model Message {
  id              String              @id @unique @default(uuid())
  converstation   DirectConversation @relation(fields: [conversation_id], references: [id])
  conversation_id String
  sender          User                @relation("message-sent", fields: [sender_id], references: [id])
  sender_id       String
  receiver        User                @relation("message-received", fields: [receiver_id], references: [id])
  receiver_id     String
  type            String
  seen            Boolean             @default(false)
  text_message    TextMessage?
  photo_message   PhotoMessage?
  video_message   VideoMessage?
  date_created    DateTime            @default(now())
}

model RoomMessage {
  id            String        @id @unique @default(uuid())
  sender        User          @relation("room-message-sender", fields: [sender_id], references: [id])
  sender_id     String
  room_id       String
  text_message  TextMessage?
  photo_message PhotoMessage?
  video_Message VideoMessage?
  date_created  DateTime      @default(now())
}

model TextMessage {
  id              String       @id @unique @default(uuid())
  message         Message?     @relation(fields: [message_id], references: [id])
  message_id      String?      @unique
  room_message    RoomMessage? @relation(fields: [room_message_id], references: [id])
  room_message_id String?      @unique
  content         String
  date_created    DateTime     @default(now())
}

model PhotoMessage {
  id              String       @id @unique @default(uuid())
  message         Message?     @relation(fields: [message_id], references: [id])
  message_id      String?      @unique
  room_message    RoomMessage? @relation(fields: [room_message_id], references: [id])
  room_message_id String?      @unique
  photo_url       String
  date_created    DateTime     @default(now())
}

model VideoMessage {
  id              String       @id @unique @default(uuid())
  message         Message?     @relation(fields: [message_id], references: [id])
  message_id      String?      @unique
  room_message    RoomMessage? @relation(fields: [room_message_id], references: [id])
  room_message_id String?      @unique
  video_url       String
  name            String
  length          Int
  date_created    DateTime     @default(now())
}

model Otp {
  id           String   @id @unique @default(uuid())
  email        String
  value        String
  date_created DateTime @default(now())
}
