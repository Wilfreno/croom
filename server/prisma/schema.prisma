// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String          @id @unique @default(uuid())
  email                   String          @unique
  display_name            String
  user_name               String
  password                String?
  profile_pic             Photo?
  birth_date              DateTime?
  messages                Message[]
  rooms                   Room[]
  provider                String?
  friend_request_received FriendRequest[] @relation("friendRequestReceiver")
  friend_request_send     FriendRequest[] @relation("friendRequestSender")
  friends                 Friendship[]    @relation("friend")

  created_at DateTime @default(now())
}

model Room {
  id         String    @id @unique @default(uuid())
  name       String
  members    User[]
  messages   Message[]
  created_at DateTime  @default(now())
}

model Message {
  id         String   @id @unique @default(uuid())
  owner      User?    @relation(fields: [owner_id], references: [id])
  owner_id   String?
  room       Room?    @relation(fields: [room_id], references: [id])
  room_id    String?
  type       String
  text       String?
  photos     Photo[]
  video      Video?
  created_at DateTime @default(now())
}

model Photo {
  id         String   @id @unique @default(uuid())
  owner      User?    @relation(fields: [owner_id], references: [id])
  owner_id   String?  @unique
  message    Message? @relation(fields: [message_id], references: [id])
  message_id String?
  photo_url  String
  created_at DateTime @default(now())
}

model Video {
  id         String   @id @unique @default(uuid())
  message    Message  @relation(fields: [message_id], references: [id])
  message_id String   @unique
  video_url  String
  name       String
  length     Int
  created_at DateTime @default(now())
}

model Otp {
  id         String   @id @unique @default(uuid())
  email      String
  value      String
  created_at DateTime @default(now())
}

model FriendRequest {
  receiver    User   @relation("friendRequestReceiver", fields: [receiver_id], references: [id])
  receiver_id String
  sender      User   @relation("friendRequestSender", fields: [sender_id], references: [id])
  sender_id   String

  @@id([receiver_id, sender_id])
}

model Friendship {
  id String @id @unique @default(uuid())

  friend    User   @relation("friend", fields: [friend_id], references: [id])
  friend_id String

  created_at DateTime @default(now())
}
