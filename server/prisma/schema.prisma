generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String          @id @unique @default(uuid())
  email                   String          @unique
  password                String?
  created_at              DateTime        @default(now())
  birth_date              DateTime?
  display_name            String
  user_name               String
  provider                String?
  rooms                   Room[]          @relation("RoomToUser")
  friend_request_received FriendRequest[] @relation("friend-request-received")
  friend_request_sent     FriendRequest[] @relation("friend-request-sent")
  friends                 Friendship[]    @relation("friend1")
  friends_with            Friendship[]    @relation("friend2")
  photo_messages_sent     PhotoMessage[]  @relation("photo-sent")
  photo_messages_received PhotoMessage[]  @relation("photo-received")
  profile_pic             ProfilePhoto?
  text_messages_sent      TextMessage[]   @relation("text-sent")
  text_messages_received  TextMessage[]   @relation("text-received")
  video_messages_sent     VideoMessage[]  @relation("video-sent")
  video_messages_received VideoMessage[]  @relation("video-received")
}

model ProfilePhoto {
  id         String   @id @unique @default(uuid())
  owner_id   String   @unique
  photo_url  String
  created_at DateTime @default(now())
  owner      User     @relation(fields: [owner_id], references: [id])
}

model Room {
  id             String         @id @unique @default(uuid())
  name           String
  created_at     DateTime       @default(now())
  photo_messages PhotoMessage[]
  text_messages  TextMessage[]
  video_messages VideoMessage[]
  members        User[]         @relation("RoomToUser")
}

model TextMessage {
  id               String   @id @unique @default(uuid())
  sender_id        String
  user_receiver_id String?
  room_receiver_id String
  content          String
  created_at       DateTime @default(now())
  room_receiver    Room     @relation(fields: [room_receiver_id], references: [id])
  sender           User     @relation("text-sent", fields: [sender_id], references: [id])
  user_receiver    User?    @relation("text-received", fields: [user_receiver_id], references: [id])
}

model PhotoMessage {
  id               String   @id @unique @default(uuid())
  sender_id        String
  user_receiver_id String?
  room_receiver_id String
  photo_url        String
  created_at       DateTime @default(now())
  room_receiver    Room     @relation(fields: [room_receiver_id], references: [id])
  sender           User     @relation("photo-sent", fields: [sender_id], references: [id])
  user_receiver    User?    @relation("photo-received", fields: [user_receiver_id], references: [id])
}

model VideoMessage {
  id               String   @id @unique @default(uuid())
  sender_id        String
  user_receiver_id String?
  room_receiver_id String
  video_url        String
  name             String
  length           Int
  created_at       DateTime @default(now())
  room_receiver    Room     @relation(fields: [room_receiver_id], references: [id])
  sender           User     @relation("video-sent", fields: [sender_id], references: [id])
  user_receiver    User?    @relation("video-received", fields: [user_receiver_id], references: [id])
}

model Otp {
  id         String   @id @unique @default(uuid())
  email      String
  value      String
  created_at DateTime @default(now())
}

model FriendRequest {
  receiver_id  String
  sender_id    String
  id           String   @id @unique @default(uuid())
  date_created DateTime @default(now())
  receiver     User     @relation("friend-request-received", fields: [receiver_id], references: [id])
  sender       User     @relation("friend-request-sent", fields: [sender_id], references: [id])

  @@unique([sender_id, receiver_id])
}

model Friendship {
  created_at  DateTime @default(now())
  friend_1_id String
  friend_2_id String
  id          String   @id @unique @default(uuid())
  user_1      User     @relation("friend1", fields: [friend_1_id], references: [id], onDelete: Cascade)
  user_2      User     @relation("friend2", fields: [friend_2_id], references: [id], onDelete: Cascade)

  @@unique([friend_1_id, friend_2_id])
}
