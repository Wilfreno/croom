generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                       String          @id @unique @default(uuid())
  email                    String          @unique
  password                 String?
  profile_photo            ProfilePhoto?
  birth_date               DateTime?
  display_name             String
  user_name                String
  provider                 String?
  friend_request_sent      FriendRequest[] @relation("friend-request-sender")
  friend_request_received  FriendRequest[] @relation("friend-request-receiver")
  friends                  Friendship[]    @relation("friend1")
  friendw_with             Friendship[]    @relation("friend2")
  direct_messages_sent     DirectMessage[] @relation("dm-sender")
  direct_messages_received DirectMessage[] @relation("dm-receiver")
  rooms                    Room[]          @relation("room-to-user")
  room_mesages_sent        RoomMessage[]   @relation("room-message-sender")
  created_at               DateTime        @default(now())
}

model ProfilePhoto {
  id         String   @id @unique @default(uuid())
  owner      User     @relation(fields: [owner_id], references: [id])
  owner_id   String   @unique
  photo_url  String
  created_at DateTime @default(now())
}

model Room {
  id         String        @id @unique @default(uuid())
  name       String
  members    User[]        @relation("room-to-user")
  messages   RoomMessage[]
  created_at DateTime      @default(now())
}

model DirectMessage {
  id             String         @id @unique @default(uuid())
  sender         User           @relation("dm-sender", fields: [sender_id], references: [id])
  sender_id      String
  receiver       User           @relation("dm-receiver", fields: [receiver_id], references: [id])
  receiver_id    String
  text_messages  TextMessage[]
  photo_messages PhotoMessage[]
  video_message  VideoMessage[]
  created_at     DateTime       @default(now())
}

model RoomMessage {
  id             String         @id @unique @default(uuid())
  sender         User           @relation("room-message-sender", fields: [sender_id], references: [id])
  sender_id      String
  room           Room           @relation(fields: [room_id], references: [id])
  room_id        String
  text_messages  TextMessage[]
  photo_messages PhotoMessage[]
  video_Message  VideoMessage[]
  created_at     DateTime       @default(now())
}

model TextMessage {
  id                String         @id @unique @default(uuid())
  direct_message    DirectMessage? @relation(fields: [direct_message_id], references: [id])
  direct_message_id String?
  room_message      RoomMessage?   @relation(fields: [room_message_id], references: [id])
  room_message_id   String?
  content           String
  created_at        DateTime       @default(now())
}

model PhotoMessage {
  id                String         @id @unique @default(uuid())
  direct_message    DirectMessage? @relation(fields: [direct_message_id], references: [id])
  direct_message_id String?
  room_message      RoomMessage?   @relation(fields: [room_message_id], references: [id])
  room_message_id   String?
  photo_url         String
  created_at        DateTime       @default(now())
}

model VideoMessage {
  id                String         @id @unique @default(uuid())
  direct_message    DirectMessage? @relation(fields: [direct_message_id], references: [id])
  direct_message_id String?
  room_message      RoomMessage?   @relation(fields: [room_message_id], references: [id])
  room_message_id   String?
  video_url         String
  name              String
  length            Int
  created_at        DateTime       @default(now())
}

model Otp {
  id         String   @id @unique @default(uuid())
  email      String
  value      String
  created_at DateTime @default(now())
}

model FriendRequest {
  id           String   @id @unique @default(uuid())
  receiver     User     @relation("friend-request-receiver", fields: [receiver_id], references: [id])
  receiver_id  String
  sender       User     @relation("friend-request-sender", fields: [sender_id], references: [id])
  sender_id    String
  date_created DateTime @default(now())

  @@unique([sender_id, receiver_id])
}

model Friendship {
  id          String   @id @unique @default(uuid())
  friend_1    User     @relation("friend1", fields: [friend_1_id], references: [id], onDelete: Cascade)
  friend_1_id String
  friend_2    User     @relation("friend2", fields: [friend_2_id], references: [id], onDelete: Cascade)
  friend_2_id String
  created_at  DateTime @default(now())

  @@unique([friend_1_id, friend_2_id])
}
