// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                       String          @id @default(auto()) @map("_id") @db.ObjectId
  email                    String          @unique
  display_name             String
  user_name                String
  password                 String?
  profile_pic              ProfilePic?
  birth_date               DateTime?
  messages                 Message[]
  provider                 String?
  rooms                    Room[]          @relation(fields: [room_ids], references: [id])
  room_ids                 String[]        @db.ObjectId
  friend_requests_sent     FriendRequest[] @relation("sender")
  friend_requests_received FriendRequest[] @relation("receiver")
  friendship               Friendship[]    @relation("friend1")
  friendship2              Friendship[]    @relation("friend2")

  created_at DateTime @default(now())
}

model ProfilePic {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  owner      User     @relation(fields: [owner_id], references: [id])
  owner_id   String   @unique @db.ObjectId
  photo_url  String
  created_at DateTime @default(now())
}

model Room {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  members    User[]    @relation(fields: [member_ids], references: [id])
  member_ids String[]  @db.ObjectId
  messages   Message[]
  created_at DateTime  @default(now())
}

model Message {
  id         String         @id @default(auto()) @map("_id") @db.ObjectId
  owner      User?          @relation(fields: [owner_id], references: [id])
  owner_id   String?        @db.ObjectId
  room       Room?          @relation(fields: [room_id], references: [id])
  room_id    String?        @db.ObjectId
  type       String
  text       String?
  photos     PhotoMessage[]
  video      VideoMessage[]
  created_at DateTime       @default(now())
}

model PhotoMessage {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  message    Message? @relation(fields: [message_id], references: [id])
  message_id String?  @db.ObjectId
  photo_url  String
  created_at DateTime @default(now())
}

model VideoMessage {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  message    Message  @relation(fields: [message_id], references: [id])
  message_id String   @db.ObjectId
  video_url  String
  name       String
  length     Int
  created_at DateTime @default(now())
}

model Otp {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  email      String
  value      String
  created_at DateTime @default(now())
}

model FriendRequest {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  receiver    User   @relation("receiver", fields: [receiver_id], references: [id])
  receiver_id String @db.ObjectId
  sender      User   @relation("sender", fields: [sender_id], references: [id])
  sender_id   String @db.ObjectId

  date_created DateTime @default(now())

  @@unique([sender_id, receiver_id])
}

model Friendship {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  user_1      User   @relation("friend1", fields: [friend_1_id], references: [id])
  friend_1_id String @db.ObjectId
  user_2      User   @relation("friend2", fields: [friend_2_id], references: [id])
  friend_2_id String @db.ObjectId

  created_at DateTime @default(now())

  @@unique([friend_1_id, friend_2_id])
}
